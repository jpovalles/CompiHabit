{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "app/(auth)/login.jsx",
    "app/(auth)/register.jsx",
    "app/_layout.jsx",
    "app/index.jsx",
    "app/test.jsx",
    "components/FancyButton.jsx",
    "components/FancyInput.jsx",
    "components/button.jsx"
  ]
}
