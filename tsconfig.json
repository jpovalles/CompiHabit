{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "src/app/(auth)/login.jsx",
    "src/app/(auth)/register.jsx",
    "src/app/_layout.jsx",
    "src/app/index.jsx",
    "src/app/test.jsx",
    "src/components/FancyButton.jsx",
    "src/components/FancyInput.jsx",
    "src/components/button.jsx",
    "src/screens/pacts/active/index.jsx"
  ]
}